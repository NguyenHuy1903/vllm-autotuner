            "date": 1775183538003,
            "name": "Commit-0",
            "content": "\n<style>\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: var(--font-sans); }\n.wrap { padding: 1rem 0; }\n.filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 1.25rem; }\n.filter-btn { font-size: 12px; padding: 5px 12px; border-radius: 20px; border: 0.5px solid var(--color-border-secondary); background: transparent; color: var(--color-text-secondary); cursor: pointer; transition: all 0.15s; }\n.filter-btn.active { background: var(--color-background-secondary); color: var(--color-text-primary); border-color: var(--color-border-primary); font-weight: 500; }\ntable { width: 100%; border-collapse: collapse; font-size: 13px; table-layout: fixed; }\nthead th { font-size: 11px; font-weight: 500; color: var(--color-text-secondary); text-transform: uppercase; letter-spacing: 0.05em; padding: 8px 10px; border-bottom: 0.5px solid var(--color-border-tertiary); text-align: left; }\nthead th:nth-child(1) { width: 42px; }\nthead th:nth-child(2) { width: 180px; }\nthead th:nth-child(3) { width: 72px; }\nthead th:nth-child(4) { width: 80px; }\nthead th:nth-child(5) { width: auto; }\nthead th:nth-child(6) { width: 80px; }\ntr.row { border-bottom: 0.5px solid var(--color-border-tertiary); }\ntr.row:hover { background: var(--color-background-secondary); }\ntd { padding: 10px 10px; vertical-align: top; color: var(--color-text-primary); }\n.rank { font-size: 12px; font-weight: 500; color: var(--color-text-secondary); text-align: center; }\n.rank-top { color: #1D9E75; font-weight: 600; }\n.name-cell a { color: var(--color-text-info); text-decoration: none; font-weight: 500; font-size: 13px; line-height: 1.4; }\n.name-cell a:hover { text-decoration: underline; }\n.score { display: flex; gap: 2px; }\n.dot { width: 8px; height: 8px; border-radius: 50%; }\n.dot.fill { background: #1D9E75; }\n.dot.empty { background: var(--color-border-tertiary); }\n.layer-tag { display: inline-block; font-size: 10px; font-weight: 500; padding: 2px 7px; border-radius: 10px; margin: 1px 2px 1px 0; }\n.l1 { background: #E6F1FB; color: #185FA5; }\n.l2 { background: #FAEEDA; color: #854F0B; }\n.l3 { background: #EAF3DE; color: #3B6D11; }\n.safe { background: #FBEAF0; color: #993556; }\n.lic-ok { font-size: 11px; padding: 2px 7px; border-radius: 10px; background: #EAF3DE; color: #3B6D11; font-weight: 500; }\n.lic-warn { font-size: 11px; padding: 2px 7px; border-radius: 10px; background: #FAEEDA; color: #854F0B; font-weight: 500; }\n.lic-no { font-size: 11px; padding: 2px 7px; border-radius: 10px; background: #FCEBEB; color: #A32D2D; font-weight: 500; }\n.desc { font-size: 12px; color: var(--color-text-secondary); line-height: 1.5; margin-top: 3px; }\n.hidden { display: none; }\n</style>\n<div class=\"wrap\">\n<div class=\"filters\">\n  <button class=\"filter-btn active\" onclick=\"filter('all',this)\">Tất cả</button>\n  <button class=\"filter-btn\" onclick=\"filter('l1',this)\">Lớp 1 — Clinical</button>\n  <button class=\"filter-btn\" onclick=\"filter('l2',this)\">Lớp 2 — Persona</button>\n  <button class=\"filter-btn\" onclick=\"filter('l3',this)\">Lớp 3 — Dynamics</button>\n  <button class=\"filter-btn\" onclick=\"filter('safe',this)\">Safety / Edge case</button>\n</div>\n<table>\n<thead>\n  <tr>\n    <th>#</th>\n    <th>Dataset</th>\n    <th>Fit</th>\n    <th>Layer</th>\n    <th>Mô tả & Cách dùng</th>\n    <th>License</th>\n  </tr>\n</thead>\n<tbody id=\"tbody\"></tbody>\n</table>\n</div>\n<script>\nconst data = [\n  {\n    rank: 1,\n    name: \"ViMedical_Disease\",\n    url: \"https://huggingface.co/datasets/PB3002/ViMedical_Disease\",\n    score: 5,\n    layers: [\"l1\"],\n    desc: \"12K+ triệu chứng bệnh thường gặp bằng tiếng Việt — seed trực tiếp Lớp 1. Đây là nguồn gốc nhất: tiếng Việt, có sẵn clinical symptoms, phù hợp chatbot y tế VN.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 2,\n    name: \"ViMedAQA\",\n    url: \"https://huggingface.co/datasets/tmnam20/ViMedAQA\",\n    score: 5,\n    layers: [\"l1\"],\n    desc: \"~15K+ medical QA tiếng Việt generated bởi Gemini (ACL 2024). Extract clinical vignettes làm seed Lớp 1: bệnh, triệu chứng, severity. Đã có VN context sẵn.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 3,\n    name: \"Anthropic HH-RLHF\",\n    url: \"https://huggingface.co/datasets/Anthropic/hh-rlhf\",\n    score: 5,\n    layers: [\"l3\", \"safe\"],\n    desc: \"~170K helpful/harmless dialogues, chosen/rejected pairs. Mine conversation policy patterns: khi nào redirect, probe deeper, graceful exit. Đã plan trong PLAN §XIII. MIT.\",\n    lic: \"ok\", licLabel: \"✅ MIT\"\n  },\n  {\n    rank: 4,\n    name: \"UltraChat 200K\",\n    url: \"https://huggingface.co/datasets/HuggingFaceH4/ultrachat_200k\",\n    score: 5,\n    layers: [\"l3\"],\n    desc: \"200K multi-turn dialogues chất lượng cao. Extract turn-taking dynamics: information drip, topic drift, recovery — maps trực tiếp tới Lớp 3 reveal patterns & conversation branches.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 5,\n    name: \"63 Phương ngữ\",\n    url: \"https://arxiv.org/abs/2410.03458\",\n    score: 5,\n    layers: [\"l2\"],\n    desc: \"102h speech từ 63 tỉnh thành. Critical cho Bắc/Trung/Nam persona diversity theo Lớp 2. Extract dialectal patterns từ transcript → enrich 397B prompt với register vùng miền.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 6,\n    name: \"VOZ-HSD\",\n    url: \"https://huggingface.co/datasets/sonlam1102/vithsd\",\n    score: 4,\n    layers: [\"l2\", \"l3\"],\n    desc: \"10M+ comments VOZ forum — informal register, slang, sarcasm thực tế người Việt. Seed cho 'The Evader' (né tránh, nói nước đôi) và informal persona miền Nam trong Lớp 2.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 7,\n    name: \"SNOMED-CT (HF)\",\n    url: \"https://huggingface.co/datasets/awacke1/SNOMED-Clinical-Terminology\",\n    score: 4,\n    layers: [\"l1\"],\n    desc: \"390K+ clinical concepts + relationships. Dùng làm từ điển seed: map symptom → ICD-10 code. Critical để đạt DoD: tag 100% ICD-10 cho ≥1,100 presentations.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 8,\n    name: \"Aegis 2.0\",\n    url: \"https://huggingface.co/datasets/nvidia/Aegis-AI-Content-Safety-Dataset-2.0\",\n    score: 4,\n    layers: [\"safe\", \"l3\"],\n    desc: \"~26K samples, 5K 'safe refusal' dạy HOW to refuse gracefully. Trực tiếp cho 'The Hostile' archetype + DPO-Safety: validate emotion, không defensive, offer graceful exit.\",\n    lic: \"ok\", licLabel: \"✅ NVIDIA\"\n  },\n  {\n    rank: 9,\n    name: \"MedINST\",\n    url: \"https://huggingface.co/datasets/aialt/MedINST\",\n    score: 4,\n    layers: [\"l1\"],\n    desc: \"7M+ samples, 133 biomedical NLP tasks (NER, RE, QA). Mine disease/drug/symptom clusters → translate + adapt làm clinical scenario seeds. English, cần translate.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 10,\n    name: \"ViMedNER\",\n    url: \"https://github.com/tdtrinh11/ViMedNer\",\n    score: 4,\n    layers: [\"l1\"],\n    desc: \"Vietnamese medical NER: nhận diện thực thể y khoa (bệnh, triệu chứng, giải phẫu) trong văn bản tiếng Việt. Enrich clinical scenario vocabulary Lớp 1.\",\n    lic: \"warn\", licLabel: \"⚠️ Verify\"\n  },\n  {\n    rank: 11,\n    name: \"MedQA (USMLE)\",\n    url: \"https://huggingface.co/datasets/bigbio/med_qa\",\n    score: 4,\n    layers: [\"l1\"],\n    desc: \"~12K clinical vignettes USMLE Steps 1-3. Extract patient case scenario structure (không phải Q&A part): chief complaint, HPI, comorbidities → translate → Lớp 1 seed.\",\n    lic: \"ok\", licLabel: \"✅ Permissive\"\n  },\n  {\n    rank: 12,\n    name: \"WildGuardMix\",\n    url: \"https://huggingface.co/datasets/allenai/wildguardmix\",\n    score: 3,\n    layers: [\"safe\", \"l3\"],\n    desc: \"92K labeled examples, 13 risk categories. Mine off-topic/adversarial patterns cho 'The Derailed' (politics, religion, math, gossip) — 50+ off-topic trigger scenarios trong Coverage Target §3.3.\",\n    lic: \"ok\", licLabel: \"✅ Apache 2.0\"\n  },\n  {\n    rank: 13,\n    name: \"UTS_Dictionary\",\n    url: \"https://huggingface.co/datasets/undertheseanlp/UTS_Dictionary\",\n    score: 3,\n    layers: [\"l2\"],\n    desc: \"Open-source Vietnamese dictionary: slang, idioms, thuật ngữ chuyên ngành. Enrich language register spectrum Lớp 2: từ formal clinic → informal miền Nam, code-switching.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 14,\n    name: \"PKU-SafeRLHF\",\n    url: \"https://huggingface.co/datasets/PKU-Alignment/PKU-SafeRLHF\",\n    score: 3,\n    layers: [\"safe\"],\n    desc: \"265K pairs với separate helpfulness + harmlessness labels, 19 harm types × 3 severity. Dùng cho DPO phase: phân biệt 'helpful but inappropriate' vs 'safe refusal'.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 15,\n    name: \"WildJailbreak\",\n    url: \"https://huggingface.co/datasets/allenai/wildjailbreak\",\n    score: 3,\n    layers: [\"safe\"],\n    desc: \"262K real in-the-wild attacks. Relevant cho 50+ off-topic trigger scenarios, DPO-Safety adversarial edge cases. Không dùng trực tiếp — mine pattern types.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 16,\n    name: \"Vietnamese TB NER\",\n    url: \"https://huggingface.co/datasets?search=Vietnamese-TB-NER\",\n    score: 3,\n    layers: [\"l1\"],\n    desc: \"NER chuyên biệt cho bệnh lao phổi (LREC 2022). Relevant cho Tier B Truyền nhiễm — module dịch tễ: tiếp xúc, lây lan, đặc thù R component của khoa này.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  },\n  {\n    rank: 17,\n    name: \"MIMIC-IV\",\n    url: \"https://physionet.org/content/mimiciv/\",\n    score: 2,\n    layers: [\"l1\"],\n    desc: \"300K+ patients, de-identified clinical notes. PLAN §XIII: chỉ tham khảo pipeline architecture — KHÔNG dùng data thực. Cần PhysioNet credential + commercial restricted.\",\n    lic: \"no\", licLabel: \"❌ Arch only\"\n  },\n  {\n    rank: 18,\n    name: \"MT-Bench\",\n    url: \"https://huggingface.co/datasets/lmsys/mt_bench_human_judgments\",\n    score: 2,\n    layers: [\"l3\"],\n    desc: \"80 multi-turn questions với GPT-4 judge. Dùng làm calibration reference cho conversation quality eval — không phải training source trực tiếp.\",\n    lic: \"ok\", licLabel: \"✅ OK\"\n  }\n];\n\nlet active = 'all';\nfunction filter(tag, btn) {\n  active = tag;\n  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));\n  btn.classList.add('active');\n  render();\n}\n\nfunction render() {\n  const tbody = document.getElementById('tbody');\n  tbody.innerHTML = '';\n  let visRank = 0;\n  data.forEach(d => {\n    const show = active === 'all' || d.layers.includes(active);\n    if (!show) return;\n    visRank++;\n    const isTop = d.score === 5;\n    const dots = Array.from({length: 5}, (_,i) =>\n      `<div class=\"dot ${i < d.score ? 'fill' : 'empty'}\"></div>`\n    ).join('');\n    const layerTags = d.layers.map(l => {\n      const labels = {l1:'Lớp 1', l2:'Lớp 2', l3:'Lớp 3', safe:'Safety'};\n      return `<span class=\"layer-tag ${l}\">${labels[l]}</span>`;\n    }).join('');\n    const licClass = d.lic === 'ok' ? 'lic-ok' : d.lic === 'warn' ? 'lic-warn' : 'lic-no';\n    tbody.innerHTML += `\n    <tr class=\"row\">\n      <td class=\"rank ${isTop ? 'rank-top' : ''}\">${visRank}</td>\n      <td class=\"name-cell\">\n        <a href=\"${d.url}\" target=\"_blank\">${d.name}</a>\n      </td>\n      <td><div class=\"score\">${dots}</div></td>\n      <td>${layerTags}</td>\n      <td><div class=\"desc\">${d.desc}</div></td>\n      <td><span class=\"${licClass}\">${d.licLabel}</span></td>\n    </tr>`;\n  });\n}\nrender();\n</script>\n"
        }
    ]
}